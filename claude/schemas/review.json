{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeReview",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "findings"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["approved", "changes_requested", "blocked"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "message": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      }
    }
  }
}
