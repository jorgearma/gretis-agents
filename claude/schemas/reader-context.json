{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeReaderContext",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "improved_prompt",
    "tech_stack",
    "context_summary",
    "primary_reader",
    "selected_readers",
    "maps_used",
    "files_to_open",
    "files_to_review",
    "reason"
  ],
  "properties": {
    "improved_prompt": {
      "type": "string",
      "description": "Version mejorada y tecnicamente precisa del prompt original del operador."
    },
    "tech_stack": {
      "type": "array",
      "items": { "type": "string" }
    },
    "context_summary": {
      "type": "string"
    },
    "primary_reader": {
      "type": "string",
      "enum": ["project-reader", "db-reader", "query-reader", "ui-reader",
               "api-reader", "services-reader", "jobs-reader"]
    },
    "selected_readers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["project-reader", "db-reader", "query-reader", "ui-reader",
                 "api-reader", "services-reader", "jobs-reader"]
      }
    },
    "maps_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["PROJECT_MAP.json", "DB_MAP.json", "QUERY_MAP.json", "UI_MAP.json",
                 "API_MAP.json", "SERVICES_MAP.json", "JOBS_MAP.json"]
      }
    },
    "files_to_open": {
      "type": "array",
      "description": "Archivos principales donde ocurre el cambio, con hints para el planner.",
      "items": { "$ref": "#/$defs/file_hint" }
    },
    "files_to_review": {
      "type": "array",
      "description": "Archivos de soporte, dependencias o referencias, con hints para el planner.",
      "items": { "$ref": "#/$defs/file_hint" }
    },
    "reason": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["ready", "blocked_no_maps", "blocked_pending_clarification"]
    },
    "map_scan_requested": {
      "type": "boolean"
    },
    "dependency_graph": {
      "type": "object",
      "description": "Grafo de dependencias forward filtrado: solo archivos relevantes para la tarea. Clave: ruta del archivo. Valor: array de rutas que importa. Identifica qué cambios propagan hacia dónde.",
      "additionalProperties": { "type": "array", "items": { "type": "string" } }
    },
    "problems_in_scope": {
      "type": "array",
      "description": "Problemas detectados en archivos involucrados en esta tarea.",
      "items": {
        "type": "object",
        "properties": {
          "file":        { "type": "string" },
          "type":        { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "env_vars_needed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Variables de entorno necesarias para las integraciones en scope."
    },
    "schema_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Archivos de schema/validación relevantes para la tarea."
    }
  },
  "$defs": {
    "file_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Ruta relativa al archivo."
        },
        "hint": {
          "type": "string",
          "description": "Descripcion breve del rol del archivo en el contexto de esta tarea."
        },
        "key_symbols": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Funciones, clases o constantes que el planner debe buscar en este archivo."
        },
        "estimated_relevance": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "high = el cambio ocurre aqui. medium = referencia directa. low = contexto de fondo."
        },
        "test_file": {
          "type": ["string", "null"],
          "description": "Ruta del archivo de test asociado, si existe."
        }
      }
    }
  }
}
