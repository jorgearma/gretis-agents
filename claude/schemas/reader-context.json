{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeReaderContext",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "primary_reader",
    "selected_readers",
    "maps_used",
    "files_to_open",
    "files_to_review",
    "reason"
  ],
  "properties": {
    "primary_reader": {
      "type": "string",
      "enum": ["project-reader", "db-reader", "query-reader", "ui-reader"]
    },
    "selected_readers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["project-reader", "db-reader", "query-reader", "ui-reader"]
      }
    },
    "maps_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["PROJECT_MAP.md", "DB_MAP.md", "QUERY_MAP.md", "UI_MAP.md"]
      }
    },
    "files_to_open": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files_to_review": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["ready", "blocked_no_maps"],
      "description": "Omitir cuando el flujo es normal. Presente solo cuando el reader no puede continuar."
    },
    "map_scan_requested": {
      "type": "boolean",
      "description": "true cuando el reader solicita aprobacion para escanear el repositorio y poblar los MAPs."
    }
  }
}
