{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudePlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["task", "steps", "risks", "done_criteria", "context_inputs"],
  "properties": {
    "task": {
      "type": "string"
    },
    "context_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_readers", "maps_used", "files_to_open", "files_to_review"],
      "properties": {
        "selected_readers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["project-reader", "db-reader", "query-reader", "ui-reader"]
          }
        },
        "maps_used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files_to_open": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files_to_review": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependency_graph": {
          "type": "object",
          "description": "Grafo de dependencias forward filtrado del reader. Clave: ruta del archivo. Valor: array de rutas que importa. Usalo para identificar qué cambios se propagan hacia dónde.",
          "additionalProperties": { "type": "array", "items": { "type": "string" } }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "owner"],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "owner": {
            "type": "string",
            "enum": ["frontend", "backend", "reviewer", "test-runner"]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "done_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "impact_analysis": {
      "type": "object",
      "description": "Analisis de impacto generado por el planner tras leer el codigo real.",
      "additionalProperties": false,
      "required": ["files_affected", "breaking_changes", "migration_needed"],
      "properties": {
        "files_affected":    { "type": "integer", "description": "Numero de archivos que el cambio modifica directamente." },
        "endpoints_affected": { "type": "array", "items": { "type": "string" }, "description": "Endpoints o rutas publicas que cambian de contrato." },
        "breaking_changes":  { "type": "array", "items": { "type": "string" }, "description": "Cambios incompatibles hacia atras. Ej: firma de funcion, contrato de API." },
        "migration_needed":  { "type": "boolean", "description": "true si el cambio requiere migracion de datos o schema." },
        "notes":             { "type": "string" }
      }
    },
    "rollback_plan": {
      "type": "object",
      "description": "Plan de rollback para revertir el cambio si algo falla en produccion.",
      "additionalProperties": false,
      "required": ["enabled", "steps"],
      "properties": {
        "enabled": { "type": "boolean" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action", "owner"],
            "properties": {
              "action": { "type": "string" },
              "owner":  { "type": "string", "enum": ["frontend", "backend"] }
            }
          }
        }
      }
    }
  }
}
