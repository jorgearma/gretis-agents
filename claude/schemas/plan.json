{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudePlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["task", "steps", "risks", "done_criteria", "context_inputs"],
  "properties": {
    "task": {
      "type": "string"
    },
    "context_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_readers", "maps_used", "files_to_open", "files_to_review"],
      "properties": {
        "selected_readers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["project-reader", "db-reader", "query-reader", "ui-reader"]
          }
        },
        "maps_used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files_to_open": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files_to_review": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "owner"],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "owner": {
            "type": "string",
            "enum": ["planner", "writer", "frontend", "backend", "reviewer"]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "done_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
