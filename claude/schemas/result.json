{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "artifacts", "next_steps"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "partial", "blocked"]
    },
    "summary": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
