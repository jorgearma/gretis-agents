{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeOperatorApproval",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "approved_by"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected", "replanning"]
    },
    "approved_by": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
