{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DbMap",
  "description": "Mapa de base de datos generado por analyze-repo.py. Consumido por db-reader.",
  "type": "object",
  "additionalProperties": false,
  "required": ["models"],
  "properties": {
    "orm":      { "type": ["string", "null"], "description": "ORM principal detectado." },
    "database": { "type": ["string", "null"], "description": "Infraestructura de DB detectada." },
    "connection_files": { "type": "array", "items": { "type": "string" } },
    "models": {
      "type": "array",
      "description": "Modelos ORM/entidades detectados.",
      "items": {
        "type": "object",
        "required": ["name", "file"],
        "additionalProperties": false,
        "properties": {
          "name":          { "type": "string" },
          "table":         { "type": "string", "description": "Nombre de tabla o colección." },
          "file":          { "type": "string" },
          "fields":        { "type": "array", "items": { "type": "string" }, "description": "Campos con tipo opcional. Ej: 'id:Integer', 'nombre'." },
          "relationships": { "type": "array", "items": { "type": "string" }, "description": "Nombres de las relaciones ORM." }
        }
      }
    },
    "migrations": { "type": "array", "items": { "type": "string" } },
    "seeds":      { "type": "array", "items": { "type": "string" } }
  }
}
