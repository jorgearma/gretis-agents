{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeExecutionBrief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task",
    "approval_status",
    "target_agents",
    "context_summary",
    "files_to_open",
    "files_to_review",
    "implementation_steps",
    "done_criteria"
  ],
  "properties": {
    "task": {
      "type": "string"
    },
    "approval_status": {
      "type": "string",
      "enum": ["pending_operator_review", "approved", "rejected"]
    },
    "target_agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["frontend", "backend", "reviewer", "orchestrator"]
      }
    },
    "context_summary": {
      "type": "string"
    },
    "files_to_open": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files_to_review": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "owner", "instruction"],
        "properties": {
          "id": {
            "type": "string"
          },
          "owner": {
            "type": "string",
            "enum": ["frontend", "backend", "reviewer", "orchestrator"]
          },
          "instruction": {
            "type": "string"
          },
          "expected_output": {
            "type": "string"
          }
        }
      }
    },
    "done_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "operator_action": {
      "type": "string"
    }
  }
}
